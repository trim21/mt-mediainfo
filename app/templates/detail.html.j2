<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport"
        content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>Daily Detail</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"
          crossorigin="anonymous"></script>
</head>
<body>

<div class="container mt-4">
  <p><a href="/">&larr; Back to Progress</a></p>

  <form class="row g-2 align-items-end mb-3" method="get" action="/detail">
    <div class="col-auto">
      <label for="startInput" class="form-label mb-0">Start date</label>
      <input type="date" id="startInput" name="start" class="form-control" value="{{ start }}">
    </div>
    <div class="col-auto">
      <button type="submit" class="btn btn-primary">Apply</button>
    </div>
    <div class="col-auto">
      <button type="button" class="btn btn-outline-danger" onclick="clearDailyStats()">Clear Cache</button>
    </div>
  </form>

  <h3>Average Byte Rate per Day</h3>
  <canvas id="dailyByteRateChart" style="max-height: 350px;"></canvas>
</div>

<div class="container mt-4">
  <h3>Threads & Torrents Fetched per Day</h3>
  <canvas id="dailyFetchChart" style="max-height: 350px;"></canvas>
</div>

<script>
  const NODE_COLORS = [
    {bg: 'rgba(13, 110, 253, 0.5)', border: 'rgba(13, 110, 253, 1)'},
    {bg: 'rgba(220, 53, 69, 0.5)', border: 'rgba(220, 53, 69, 1)'},
    {bg: 'rgba(25, 135, 84, 0.5)', border: 'rgba(25, 135, 84, 1)'},
    {bg: 'rgba(255, 193, 7, 0.5)', border: 'rgba(255, 193, 7, 1)'},
    {bg: 'rgba(111, 66, 193, 0.5)', border: 'rgba(111, 66, 193, 1)'},
    {bg: 'rgba(32, 201, 151, 0.5)', border: 'rgba(32, 201, 151, 1)'},
  ];

  function formatByteRate(bps) {
    if (bps === 0) return '0 B/s';
    const units = ['B/s', 'KiB/s', 'MiB/s', 'GiB/s', 'TiB/s'];
    let i = 0;
    while (bps >= 1024 && i < units.length - 1) { bps /= 1024; i++; }
    return bps.toFixed(2) + ' ' + units[i];
  }

  // Daily byte rate chart (inlined data)
  (() => {
    const data = {{ daily_byte_rate | tojson }};
    const fetchedData = {{ daily_fetched_size | tojson }};
    const labels = data.labels;
    const nodeIds = Object.keys(data.per_node);

    const fetchedMap = Object.fromEntries(fetchedData.map(d => [d.day, d.byte_rate]));

    const datasets = [
      {
        label: 'Downloaded',
        data: data.totals.map(d => d.byte_rate),
        backgroundColor: 'rgba(13, 110, 253, 0.3)',
        borderColor: 'rgba(13, 110, 253, 1)',
        borderWidth: 2,
      },
      {
        label: 'Fetched (need to download)',
        data: labels.map(l => fetchedMap[l] ?? 0),
        backgroundColor: 'rgba(220, 53, 69, 0.2)',
        borderColor: 'rgba(220, 53, 69, 1)',
        borderWidth: 2,
      },
      ...nodeIds.map((nid, i) => {
        const c = NODE_COLORS[i % NODE_COLORS.length];
        return {
          label: nid.slice(0, 8),
          data: data.per_node[nid],
          backgroundColor: c.bg,
          borderColor: c.border,
          borderWidth: 1,
          borderDash: [5, 5],
        };
      }),
    ];

    new Chart(document.getElementById('dailyByteRateChart'), {
      type: 'line',
      data: { labels, datasets },
      options: {
        responsive: true,
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              callback: value => formatByteRate(value)
            }
          }
        },
        plugins: {
          tooltip: {
            callbacks: {
              label: ctx => ctx.dataset.label + ': ' + formatByteRate(ctx.parsed.y)
            }
          },
        }
      }
    });
  })();

  // Daily fetch chart (inlined data)
  (() => {
    const threadData = {{ daily_thread_count | tojson }};
    const torrentData = {{ daily_torrent_count | tojson }};
    const doneData = {{ daily_done_count | tojson }};
    const mediainfoData = {{ daily_mediainfo_count | tojson }};

    const threadMap = Object.fromEntries(threadData.map(d => [d.day, d.count]));
    const torrentMap = Object.fromEntries(torrentData.map(d => [d.day, d.count]));
    const mediainfoMap = Object.fromEntries(mediainfoData.map(d => [d.day, d.count]));
    const allDays = [...new Set([
      ...threadData.map(d => d.day),
      ...torrentData.map(d => d.day),
      ...(doneData.labels || []),
      ...mediainfoData.map(d => d.day),
    ])].sort();

    const doneNodeIds = Object.keys(doneData.per_node || {});
    const doneTotalMap = {};
    (doneData.labels || []).forEach((l, i) => { doneTotalMap[l] = doneData.totals[i]; });
    const doneNodeMaps = {};
    doneNodeIds.forEach(nid => {
      const m = {};
      (doneData.labels || []).forEach((l, i) => { m[l] = doneData.per_node[nid][i]; });
      doneNodeMaps[nid] = m;
    });

    const doneDatasets = [
      {
        label: 'Done (total)',
        data: allDays.map(d => doneTotalMap[d] ?? 0),
        backgroundColor: 'rgba(13, 110, 253, 0.3)',
        borderColor: 'rgba(13, 110, 253, 1)',
        borderWidth: 2,
      },
      ...doneNodeIds.map((nid, i) => {
        const c = NODE_COLORS[i % NODE_COLORS.length];
        return {
          label: 'Done ' + nid.slice(0, 8),
          data: allDays.map(d => doneNodeMaps[nid][d] ?? 0),
          backgroundColor: c.bg,
          borderColor: c.border,
          borderWidth: 1,
          borderDash: [5, 5],
        };
      }),
    ];

    new Chart(document.getElementById('dailyFetchChart'), {
      type: 'line',
      data: {
        labels: allDays,
        datasets: [
          {
            label: 'Threads Fetched',
            data: allDays.map(d => threadMap[d] ?? 0),
            backgroundColor: 'rgba(25, 135, 84, 0.5)',
            borderColor: 'rgba(25, 135, 84, 1)',
            borderWidth: 1,
          },
          {
            label: 'Mediainfo Fetched',
            data: allDays.map(d => mediainfoMap[d] ?? 0),
            backgroundColor: 'rgba(111, 66, 193, 0.5)',
            borderColor: 'rgba(111, 66, 193, 1)',
            borderWidth: 1,
          },
          {
            label: 'Torrents Fetched',
            data: allDays.map(d => torrentMap[d] ?? 0),
            backgroundColor: 'rgba(255, 193, 7, 0.5)',
            borderColor: 'rgba(255, 193, 7, 1)',
            borderWidth: 1,
          },
          ...doneDatasets,
        ]
      },
      options: {
        responsive: true,
        scales: { y: { beginAtZero: true } },
      }
    });
  })();

  function clearDailyStats() {
    if (!confirm('Clear daily stats cache? Charts will recompute on next load.')) return;
    fetch('/api/daily-stats/clear', {method: 'POST'})
      .then(r => r.json())
      .then(() => location.reload());
  }
</script>
</body>
</html>
