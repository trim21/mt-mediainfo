<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport"
        content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>{{ title }}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">
  <style>
    .reason-cell { max-width: 400px; }
    .reason-short { cursor: pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 400px; }
    .reason-full { display: none; white-space: pre-wrap; word-break: break-all; font-size: 0.75rem; max-height: 300px; overflow-y: auto; }
    .reason-cell.expanded .reason-short { display: none; }
    .reason-cell.expanded .reason-full { display: block; }
  </style>
</head>
<body>

<div class="container-fluid mt-4 px-4">
  <p><a href="/">&larr; Back to Progress</a></p>
  <h2>{{ title }} <small class="text-muted fs-6">({{ total_count }})</small></h2>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <div class="text-muted small">Page {{ page }} / {{ total_pages }}{% if total_count %} · Showing {{ threads | length }} of {{ total_count }}{% endif %}</div>
    <div class="btn-group btn-group-sm" role="group" aria-label="Pagination">
      <a class="btn btn-outline-secondary{% if not has_prev %} disabled{% endif %}" href="?page={{ prev_page if prev_page else 1 }}">Previous</a>
      <a class="btn btn-outline-secondary{% if not has_next %} disabled{% endif %}" href="?page={{ next_page if next_page else total_pages }}">Next</a>
    </div>
  </div>

  <table class="table table-bordered table-hover table-sm">
    <thead class="table-light">
    <tr>
      <th>TID</th>
      <th>Category</th>
      <th>Size</th>
      <th>Selected Size</th>
      <th>Seeders</th>
      {% if show_progress %}<th>Progress</th>{% endif %}
      {% if show_failed_reason %}<th>Reason</th>{% endif %}
      <th>Created</th>
      <th>Link</th>
      {% if show_reset %}<th>Action</th>{% endif %}
    </tr>
    </thead>
    <tbody>
    {% for t in threads %}
    <tr id="row-{{ t.tid }}">
      <td>{{ t.tid }}</td>
      <td>{{ t.category }}</td>
      <td>{{ t.size_fmt }}</td>
      <td>{{ t.selected_size_fmt }}</td>
      <td>{{ t.seeders }}</td>
      {% if show_progress %}<td>{{ "%.1f" | format(t.progress * 100) }}%</td>{% endif %}
      {% if show_failed_reason %}
      <td class="reason-cell" onclick="this.classList.toggle('expanded')">
        <div class="reason-short" title="{{ t.failed_reason }}">{{ t.failed_reason.split('\n')[0] }}</div>
        <div class="reason-full">{{ t.failed_reason }}</div>
      </td>
      {% endif %}
      <td>{{ t.created_at | fmt_dt }}</td>
      <td><a href="https://kp.m-team.cc/detail/{{ t.tid }}" target="_blank">MT</a></td>
      {% if show_reset %}<td><button class="btn btn-outline-primary btn-sm" onclick="resetOne({{ t.tid }})">Reset</button></td>{% endif %}
    </tr>
    {% endfor %}
    </tbody>
  </table>
</div>

{% if show_reset %}
<script>
async function resetOne(tid) {
  if (!confirm('Reset thread ' + tid + '?')) return;
  const resp = await fetch('/api/thread/' + tid + '/reset', {method: 'POST'});
  if (resp.ok) {
    document.getElementById('row-' + tid)?.remove();
  } else {
    alert('Failed to reset');
  }
}
</script>
{% endif %}

</body>
</html>
