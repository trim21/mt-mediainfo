<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport"
        content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>{{ title }}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">
  <style>
    .reason-cell { max-width: 420px; min-width: 260px; }
    .reason-inline {
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
      min-width: 0;
    }
    .reason-summary {
      flex: 1 1 auto;
      min-width: 0;
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
    }
    .reason-link {
      flex: 0 0 auto;
      border: 0;
      background: transparent;
      padding: 0;
      color: var(--bs-link-color);
      text-decoration: underline;
      cursor: pointer;
    }
    .reason-dialog {
      width: min(1000px, calc(100vw - 2rem));
      max-height: calc(100vh - 2rem);
      border: 1px solid #ced4da;
      border-radius: 0.75rem;
      padding: 0;
    }
    .reason-dialog::backdrop { background: rgba(0, 0, 0, 0.35); }
    .reason-dialog-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      padding: 1rem 1.25rem;
      border-bottom: 1px solid #dee2e6;
    }
    .reason-dialog-title {
      margin: 0;
      font-size: 1rem;
      font-weight: 600;
      word-break: break-word;
    }
    .reason-dialog-body {
      margin: 0;
      padding: 1rem 1.25rem 1.25rem;
      max-height: calc(100vh - 10rem);
      overflow: auto;
      white-space: pre-wrap;
      word-break: break-word;
      font-size: 0.8rem;
      line-height: 1.45;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      background: #f8f9fa;
    }
  </style>
</head>
<body>

<div class="container-fluid mt-4 px-4">
  <p><a href="/">&larr; Back to Progress</a></p>
  <h2>{{ title }} <small class="text-muted fs-6">({{ total_count }})</small></h2>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <div class="text-muted small">Page {{ page }} / {{ total_pages }}{% if total_count %} · Showing {{ threads | length }} of {{ total_count }}{% endif %}</div>
    <div class="d-flex align-items-center gap-2">
      {% if show_reset_all %}
      <button type="button" class="btn btn-outline-danger btn-sm" onclick="resetAllRemoved()">Reset All</button>
      {% endif %}
      <div class="btn-group btn-group-sm" role="group" aria-label="Pagination">
        <a class="btn btn-outline-secondary{% if not has_prev %} disabled{% endif %}" href="?page={{ prev_page if prev_page else 1 }}">Previous</a>
        <a class="btn btn-outline-secondary{% if not has_next %} disabled{% endif %}" href="?page={{ next_page if next_page else total_pages }}">Next</a>
      </div>
    </div>
  </div>

  <table class="table table-bordered table-hover table-sm">
    <thead class="table-light">
    <tr>
      <th>TID</th>
      <th>Category</th>
      <th>Size</th>
      <th>Selected Size</th>
      <th>Seeders</th>
      {% if show_progress %}<th>Progress</th>{% endif %}
      {% if show_failed_reason %}<th>Reason</th>{% endif %}
      <th>Created</th>
      <th>Link</th>
      {% if show_reset %}<th>Action</th>{% endif %}
    </tr>
    </thead>
    <tbody>
    {% for t in threads %}
    <tr id="row-{{ t.tid }}">
      <td>{{ t.tid }}</td>
      <td>{{ t.category }}</td>
      <td>{{ t.size_fmt }}</td>
      <td>{{ t.selected_size_fmt }}</td>
      <td>{{ t.seeders }}</td>
      {% if show_progress %}<td>{{ "%.1f" | format(t.progress * 100) }}%</td>{% endif %}
      {% if show_failed_reason %}
      <td class="reason-cell">
        <div class="reason-inline">
          <div class="reason-summary" title="{{ t.failed_reason_preview }}">{{ t.failed_reason_preview }}</div>
          {% if t.failed_reason_has_details %}
          <button type="button" class="reason-link" data-preview="{{ t.failed_reason_preview }}" onclick="showReasonDialog(this)">Details</button>
          <template class="reason-detail-source">{{ t.failed_reason }}</template>
          {% endif %}
        </div>
      </td>
      {% endif %}
      <td>{{ t.created_at | fmt_dt }}</td>
      <td><a href="https://kp.m-team.cc/detail/{{ t.tid }}" target="_blank">MT</a></td>
      {% if show_reset %}<td><button class="btn btn-outline-primary btn-sm" onclick="resetOne({{ t.tid }})">Reset</button></td>{% endif %}
    </tr>
    {% endfor %}
    </tbody>
  </table>
</div>

{% if show_failed_reason %}
<dialog id="reason-dialog" class="reason-dialog">
  <div class="reason-dialog-header">
    <h3 id="reason-dialog-title" class="reason-dialog-title"></h3>
    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="closeReasonDialog()">Close</button>
  </div>
  <pre id="reason-dialog-body" class="reason-dialog-body"></pre>
</dialog>
{% endif %}

{% if show_reset %}
<script>
async function resetOne(tid) {
  if (!confirm('Reset thread ' + tid + '?')) return;
  const resp = await fetch('/api/thread/' + tid + '/reset', {method: 'POST'});
  if (resp.ok) {
    document.getElementById('row-' + tid)?.remove();
  } else {
    alert('Failed to reset');
  }
}

{% if show_reset_all %}
async function resetAllRemoved() {
  if (!confirm('Reset all removed jobs? This affects every job with removed-by-client status.')) return;
  const resp = await fetch('/api/threads/removed/reset-all', {method: 'POST'});
  if (resp.ok) {
    location.reload();
  } else {
    alert('Failed to reset all removed jobs');
  }
}
{% endif %}
</script>
{% endif %}

{% if show_failed_reason %}
<script>
function showReasonDialog(button) {
  const dialog = document.getElementById('reason-dialog');
  const title = document.getElementById('reason-dialog-title');
  const body = document.getElementById('reason-dialog-body');
  const cell = button.closest('.reason-cell');
  const source = cell.querySelector('.reason-detail-source');

  title.textContent = button.dataset.preview || 'Failure reason';
  body.textContent = source?.content?.textContent || '';
  dialog.showModal();
}

function closeReasonDialog() {
  document.getElementById('reason-dialog')?.close();
}
</script>
{% endif %}

</body>
</html>
