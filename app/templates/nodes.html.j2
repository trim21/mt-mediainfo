<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport"
        content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>Nodes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">
</head>
<body>

<div class="container mt-4">
  <p><a href="/">&larr; Back to Progress</a> | <a href="/rpc">RPC History</a></p>
  <h2>Nodes</h2>

  <table class="table table-bordered table-hover">
    <thead class="table-light">
    <tr>
      <th>Node</th>
      <th>Alias</th>
      <th>Version</th>
      <th>Status</th>
      <th>Last Seen</th>
      <th>Downloading</th>
      <th>Speed</th>
      <th>Done</th>
      <th>Failed</th>
      <th>Removed</th>
      <th>Total</th>
      <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    {% for n in nodes %}
    <tr>
      <td>
        <a href="/nodes/{{ n.id }}">
          {% if n.alias %}<strong>{{ n.alias }}</strong>{% else %}<code class="text-muted">{{ n.id[:8] }}</code>{% endif %}
        </a>
      </td>
      <td>
        <div class="d-flex align-items-center gap-1">
          <input type="text" class="form-control form-control-sm" style="width: 120px;"
                 id="alias-{{ loop.index }}" value="{{ n.alias }}" placeholder="{{ n.id[:8] }}">
          <button class="btn btn-sm btn-outline-secondary"
                  onclick="saveAlias('{{ n.id }}', document.getElementById('alias-{{ loop.index }}').value, this)">Save</button>
        </div>
      </td>
      <td><code>{{ n.version or '-' }}</code></td>
      <td style="max-width:120px">
        <small><code class="d-block text-truncate" title="{{ n.status }}" style="cursor:pointer" onclick="showStatus('{{ n.status }}')">{{ n.status or '-' }}</code></small>
      </td>
      <td title="{{ n.last_seen | fmt_dt }}">{{ n.last_seen | timeago }}</td>
      <td>{{ n.downloading }}</td>
      <td>{{ n.dlspeed_fmt }}</td>
      <td>{{ n.done }}</td>
      <td>{{ n.failed }}</td>
      <td>{{ n.removed }}</td>
      <td>{{ n.total }}</td>
      <td>
        <button class="btn btn-sm btn-outline-primary" onclick="pingNode('{{ n.id }}', this)">Ping</button>
        <button class="btn btn-sm btn-outline-info" onclick="showDebugInfo(this)" data-debug="{{ n.debug_info | e }}">Debug</button>
      </td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
</div>

<div class="modal fade" id="statusModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Node Status</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <pre id="statusFull"></pre>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
const statusModal = new bootstrap.Modal(document.getElementById('statusModal'));
function showStatus(text) {
  document.getElementById('statusFull').textContent = text || '(empty)';
  statusModal.show();
}

function showDebugInfo(btn) {
  const debugInfo = btn.getAttribute('data-debug') || '';
  const nodeId = btn.closest('tr').querySelector('a').textContent.trim();
  const modalTitle = document.querySelector('#statusModal .modal-title');
  modalTitle.textContent = 'Debug Info for ' + nodeId;

  let displayText = debugInfo || '(empty)';
  try {
    const parsed = JSON.parse(debugInfo);
    displayText = JSON.stringify(parsed, null, 2);
  } catch (e) {
    displayText = debugInfo || '(empty)';
  }

  document.getElementById('statusFull').textContent = displayText;
  statusModal.show();
}

async function saveAlias(nodeId, alias, btn) {
  btn.disabled = true;
  btn.textContent = '...';
  try {
    const resp = await fetch('/api/node/' + nodeId + '/alias', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({alias: alias.trim()})
    });
    if (!resp.ok) {
      btn.textContent = 'Error';
      btn.classList.replace('btn-outline-secondary', 'btn-outline-danger');
      return;
    }
    btn.textContent = 'Saved';
    btn.classList.replace('btn-outline-secondary', 'btn-outline-success');
  } catch (e) {
    btn.textContent = 'Error';
    btn.classList.replace('btn-outline-secondary', 'btn-outline-danger');
  }
  setTimeout(() => {
    btn.disabled = false;
    btn.textContent = 'Save';
    btn.className = 'btn btn-sm btn-outline-secondary';
  }, 2000);
}

async function pingNode(nodeId, btn) {
  btn.disabled = true;
  btn.textContent = '...';
  try {
    const resp = await fetch('/api/node/' + nodeId + '/rpc', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({method: 'ping', payload: {}})
    });
    const data = await resp.json();
    if (!resp.ok) {
      btn.textContent = 'Error';
      btn.classList.replace('btn-outline-primary', 'btn-outline-danger');
      return;
    }
    btn.textContent = 'Queued #' + data.id;
    btn.classList.replace('btn-outline-primary', 'btn-outline-success');
  } catch (e) {
    btn.textContent = 'Error';
    btn.classList.replace('btn-outline-primary', 'btn-outline-danger');
  }
  setTimeout(() => {
    btn.disabled = false;
    btn.textContent = 'Ping';
    btn.className = 'btn btn-sm btn-outline-primary';
  }, 5000);
}
</script>

</body>
</html>
