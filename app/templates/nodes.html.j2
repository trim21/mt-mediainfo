<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport"
        content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>Nodes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">
</head>
<body>

<div class="container mt-4">
  <p><a href="/">&larr; Back to Progress</a></p>
  <h2>Nodes</h2>

  <table class="table table-bordered table-hover">
    <thead class="table-light">
    <tr>
      <th>Node ID</th>
      <th>Last Seen</th>
      <th>Downloading</th>
      <th>Done</th>
      <th>Failed</th>
      <th>Removed</th>
      <th>Total</th>
    </tr>
    </thead>
    <tbody>
    {% for n in nodes %}
    <tr>
      <td>
        <a href="/nodes/{{ n.id }}">
          <small class="text-muted">{{ n.id }}</small>
        </a>
      </td>
      <td>{{ n.last_seen | fmt_dt }}</td>
      <td>{{ n.downloading }}</td>
      <td>{{ n.done }}</td>
      <td>{{ n.failed }}</td>
      <td>{{ n.removed }}</td>
      <td>{{ n.total }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
</div>

</body>
</html>
