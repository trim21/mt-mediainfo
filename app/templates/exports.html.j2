<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Export Records</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container mt-4">
  <h2>Export Records</h2>
  <table class="table table-bordered">
    <thead>
      <tr>
        <th>Date</th>
        <th>Status</th>
        <th>Count</th>
        <th>Error</th>
        <th>Created At</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
    {% for r in records %}
      <tr class="{% if r.status == 'success' %}table-success{% elif r.status == 'failed' %}table-danger{% else %}table-warning{% endif %}">
        <td>{{ r.export_date }}</td>
        <td>{{ r.status }}</td>
        <td>{{ r.exported_count }}</td>
        <td class="text-muted small">{{ r.error | truncate(120) }}</td>
        <td>{{ r.created_at }}</td>
        <td>
          {% if r.status in ('failed', 'running') %}
          <form method="post" action="/api/export-records/{{ r.export_date }}/reset" onsubmit="return confirm('Reset exported_at for {{ r.export_date }}?')">
            <button type="submit" class="btn btn-sm btn-warning">Reset</button>
          </form>
          {% endif %}
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
</div>
</body>
</html>
