<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport"
        content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">
  <link href="https://cdn.jsdelivr.net/npm/jquery.fancytree@2.38.3/dist/skin-lion/ui.fancytree.min.css"
        rel="stylesheet">
  <style>
    #configTree .fancytree-node { line-height: 32px; }
    #configTree .fancytree-title { font-family: monospace; font-size: 0.875rem; }
    .value-cell { word-break: break-all; }
    .value-edit > input { width: 100%; font-size: 0.875rem; }
  </style>
</head>
<body>

<div class="container mt-4">
  <p><a href="/">&larr; Back to Progress</a></p>

  <h2>Admin</h2>

  <div class="card mt-3">
    <div class="card-body">
      <h5 class="card-title">Daily Stats Cache</h5>
      <p class="card-text">Clear the cached daily stats. Charts will recompute on next page load.</p>
      <button type="button" class="btn btn-outline-danger" onclick="clearDailyStats()">Clear Cache</button>
      <span id="clearResult" class="ms-2 text-success" style="display:none;">Cleared!</span>
    </div>
  </div>

  <div class="card mt-3">
    <div class="card-body">
      <h5 class="card-title">Config</h5>
      <table id="configTree" class="table table-sm table-bordered mb-3">
        <thead>
          <tr><th style="width:35%">Key</th><th>Value</th><th style="width:130px"></th></tr>
        </thead>
        <tbody></tbody>
      </table>
      <form class="row g-2 align-items-end" id="addConfigForm">
        <div class="col-auto">
          <label class="form-label mb-1">Key</label>
          <input type="text" class="form-control form-control-sm" id="newKey" required placeholder="key">
        </div>
        <div class="col">
          <label class="form-label mb-1">Value</label>
          <input type="text" class="form-control form-control-sm" id="newValue" required placeholder="value">
        </div>
        <div class="col-auto">
          <button type="submit" class="btn btn-sm btn-primary">Add / Update</button>
        </div>
        <div class="col-auto">
          <span id="addConfigError" class="text-danger" style="display:none;"></span>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery.fancytree@2.38.3/dist/jquery.fancytree-all-deps.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery.fancytree@2.38.3/dist/modules/jquery.fancytree.table.min.js"></script>

<script>
  var TREE_DATA = {{ config | tojson | safe }};

  function escapeHtml(s) {
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(s));
    return div.innerHTML;
  }

  function renderActions(key, value) {
    if (key === 'schema_version') {
      return '<span class="badge bg-secondary">protected</span>';
    }
    return '<button class="btn btn-sm btn-outline-secondary me-1" onclick="startEdit(\'' + key + '\')">Edit</button>' +
           '<button class="btn btn-sm btn-outline-danger" onclick="deleteConfig(\'' + key + '\')">Delete</button>';
  }

  function startEdit(key) {
    var node = $('#configTree').fancytree('getTree').getNodeByKey(key);
    if (!node) return;
    var col1 = $(node.tr).find('>td').eq(1);
    col1.html('<div class="value-edit"><input type="text" value="' + escapeHtml(node.data.value || '') + '"><button class="btn btn-sm btn-primary ms-1" onclick="saveEdit(\'' + key + '\')">Save</button><button class="btn btn-sm btn-outline-secondary ms-1" onclick="location.reload()">Cancel</button></div>');
  }

  async function saveEdit(key) {
    var tr = $('#configTree').fancytree('getTree').getNodeByKey(key).tr;
    var value = $(tr).find('input').val().trim();
    if (!value) { alert('Value cannot be empty.'); return; }
    var res = await fetch('/api/config', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({key: key, value: value}),
    });
    if (res.ok) { location.reload(); } else { alert((await res.json()).error); }
  }

  async function deleteConfig(key) {
    if (!confirm('Delete config key "' + key + '"?')) return;
    var res = await fetch('/api/config/' + encodeURIComponent(key), {method: 'DELETE'});
    if (res.ok) { location.reload(); } else { alert((await res.json()).error); }
  }

  async function deleteConfigGroup(prefix) {
    if (!confirm('Delete all config keys under "' + prefix + '"?')) return;
    var res = await fetch('/api/config/delete-group', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({prefix: prefix}),
    });
    if (res.ok) { location.reload(); } else { alert((await res.json()).error); }
  }

  $(function() {
    $('#configTree').fancytree({
      extensions: ['table'],
      table: {
        indentation: 20,
        nodeColumnIdx: 0,
      },
      source: TREE_DATA,
      renderColumns: function(event, data) {
        var node = data.node;
        var $tds = $(node.tr).find('>td');
        $tds.eq(0).find('.fancytree-title').text(node.title);
        if (node.folder) {
          $tds.eq(1).text('');
          $tds.eq(2).html(
            '<span class="badge bg-light text-dark me-2">' + (node.children ? node.children.length : 0) + ' entries</span>' +
            '<button class="btn btn-sm btn-outline-danger" onclick="deleteConfigGroup(\'' + node.key + '\')">Delete group</button>'
          );
        } else {
          $tds.eq(1).html('<span class="value-cell">' + escapeHtml(node.data.value || '') + '</span>');
          $tds.eq(2).html(renderActions(node.key, node.data.value));
        }
      }
    });
  });

  function clearDailyStats() {
    if (!confirm('Clear daily stats cache? Charts will recompute on next load.')) return;
    fetch('/api/daily-stats/clear', {method: 'POST'})
      .then(function(r) { return r.json(); })
      .then(function() {
        var el = document.getElementById('clearResult');
        el.style.display = 'inline';
        setTimeout(function() { el.style.display = 'none'; }, 3000);
      });
  }

  document.getElementById('addConfigForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    var key = document.getElementById('newKey').value.trim();
    var value = document.getElementById('newValue').value.trim();
    var errEl = document.getElementById('addConfigError');
    errEl.style.display = 'none';
    var res = await fetch('/api/config', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({key: key, value: value}),
    });
    if (res.ok) {
      location.reload();
    } else {
      errEl.textContent = (await res.json()).error;
      errEl.style.display = 'inline';
    }
  });
</script>
</body>
</html>
