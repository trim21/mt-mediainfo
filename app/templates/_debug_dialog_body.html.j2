<dialog id="debug-dialog" class="debug-dialog">
  <div class="debug-dialog-header">
    <h3 id="debug-dialog-title" class="debug-dialog-title"></h3>
    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('debug-dialog').close()">Close</button>
  </div>
  <pre id="debug-dialog-body" class="debug-dialog-body"></pre>
</dialog>

<script>
async function showDebug(nodeId, infoHash) {
  const dialog = document.getElementById('debug-dialog');
  const title = document.getElementById('debug-dialog-title');
  const body = document.getElementById('debug-dialog-body');

  title.textContent = 'Debug Info';
  body.textContent = 'Loading...';
  dialog.showModal();

  try {
    const resp = await fetch('/api/job/debug-info?node_id=' + encodeURIComponent(nodeId) + '&info_hash=' + encodeURIComponent(infoHash));
    const data = await resp.json();
    if (!resp.ok) {
      body.textContent = 'Error: ' + (data.error || resp.statusText);
    } else {
      body.textContent = data.debug_info || '(empty)';
    }
  } catch (e) {
    body.textContent = 'Request failed: ' + e;
  }
}
</script>
