<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport"
        content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>{{ title }}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">
  <style>
    .mediainfo { max-height: 600px; overflow: auto; white-space: pre-wrap; word-break: break-word; font-size: 0.8rem; line-height: 1.45; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; background: #f8f9fa; padding: 1rem; border-radius: 0.375rem; }
  </style>
</head>
<body>
<div class="container-fluid mt-4 px-4">
  <p><a href="/">&larr; Back to Progress</a></p>
  <h2>{{ title }}</h2>

  <table class="table table-bordered table-sm mt-3" style="max-width: 720px;">
    <tbody>
      <tr><th class="table-light" style="width:160px">TID</th><td>{{ thread.tid }}</td></tr>
      <tr><th class="table-light">Category</th><td>{{ thread.category }}</td></tr>
      <tr><th class="table-light">Size</th><td>{{ thread.size_fmt }}</td></tr>
      <tr><th class="table-light">Selected Size</th><td>{{ thread.selected_size_fmt }}</td></tr>
      <tr><th class="table-light">Seeders</th><td>{{ thread.seeders }}</td></tr>
      <tr><th class="table-light">Info Hash</th><td style="font-family: monospace;">{{ thread.info_hash }}</td></tr>
      <tr><th class="table-light">Hardcoded Sub</th><td>{{ thread.hard_coded_subtitle }}</td></tr>
      <tr><th class="table-light">Created At</th><td>{{ thread.created_at | fmt_dt }}</td></tr>
      <tr><th class="table-light">Upload At</th><td>{{ thread.upload_at | fmt_dt }}</td></tr>
      <tr><th class="table-light">Mediainfo At</th><td>{{ thread.mediainfo_at | fmt_dt }}</td></tr>
      <tr><th class="table-light">Torrent Fetched At</th><td>{{ thread.torrent_fetched_at | fmt_dt }}</td></tr>
      <tr><th class="table-light">Torrent Invalid</th><td>{{ thread.torrent_invalid or '-' }}</td></tr>
      <tr><th class="table-light">MT Link</th><td><a href="https://kp.m-team.cc/detail/{{ thread.tid }}" target="_blank">https://kp.m-team.cc/detail/{{ thread.tid }}</a></td></tr>
    </tbody>
  </table>

  <h4 class="mt-4">Selected Files</h4>
  {% if thread.selected_files %}
  <table class="table table-bordered table-sm" style="max-width: 800px;">
    <thead class="table-light">
      <tr><th>Index</th><th>Name</th><th>Size</th><th>Selected</th></tr>
    </thead>
    <tbody>
      {% for f in thread.selected_files %}
      <tr>
        <td>{{ f.index }}</td>
        <td style="word-break: break-all;">{{ f.name }}</td>
        <td>{{ f.size }}</td>
        <td>{{ "✓" if f.selected else "" }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="text-muted">No file selection data available.</p>
  {% endif %}

  {% if thread.mediainfo %}
  <h4 class="mt-4">Mediainfo</h4>
  <pre class="mediainfo">{{ thread.mediainfo }}</pre>
  {% endif %}
</div>
</body>
</html>
