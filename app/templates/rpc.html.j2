<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport"
        content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>RPC History</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">
</head>
<body>

<div class="container-fluid mt-4 px-4">
  <p><a href="/nodes">&larr; Back to Nodes</a></p>
  <h2>RPC History <small class="text-muted fs-6">({{ commands | length }} recent)</small></h2>

  <table class="table table-bordered table-hover table-sm">
    <thead class="table-light">
    <tr>
      <th>ID</th>
      <th>Node</th>
      <th>Method</th>
      <th>Payload</th>
      <th>Status</th>
      <th>Result / Error</th>
      <th>Created</th>
      <th>Executed</th>
    </tr>
    </thead>
    <tbody>
    {% for c in commands %}
    <tr>
      <td>{{ c.id }}</td>
      <td><a href="/nodes/{{ c.node_id }}"><code>{{ c.node_id[:8] }}</code></a></td>
      <td><code>{{ c.method }}</code></td>
      <td><small>{{ c.payload }}</small></td>
      <td>
        {% if c.status == 'pending' %}<span class="badge bg-warning text-dark">pending</span>
        {% elif c.status == 'done' %}<span class="badge bg-success">done</span>
        {% elif c.status == 'error' %}<span class="badge bg-danger">error</span>
        {% endif %}
      </td>
      <td>
        {% if c.error %}<small class="text-danger">{{ c.error }}</small>
        {% elif c.result %}<small>{{ c.result }}</small>
        {% else %}-
        {% endif %}
      </td>
      <td>{{ c.created_at | fmt_dt }}</td>
      <td>{{ c.executed_at | fmt_dt }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
</div>

</body>
</html>
