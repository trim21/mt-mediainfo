<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport"
        content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>Progress</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">
</head>
<body>

<div class="container mt-4">
  <h2>Progress</h2>

  {% if failed_exports %}
  <div class="alert alert-danger" role="alert">
    <strong>Export failures:</strong>
    {% for e in failed_exports %}
      <br><a href="/exports" class="alert-link">{{ e.export_date }}</a>
    {% endfor %}
  </div>
  {% endif %}

  <div class="row">
    <div class="col-md-6">
      <h3>Scraping Progress</h3>
      <table class="table table-bordered mb-4">
        <tbody>
        <tr>
          <th><a href="/threads/all" class="text-reset text-decoration-none">Threads discovered (all categories)</a></th>
          <td>{{ scraped_total }}</td>
        </tr>
        <tr>
          <th>Total</th>
          <td>{{ total }}</td>
        </tr>
        <tr class="table-warning">
          <th><a href="/threads/pending-mediainfo" class="text-reset text-decoration-none">Pending fetch mediainfo</a></th>
          <td>{{ pending_fetch_mediainfo }}</td>
        </tr>
        <tr class="table-warning">
          <th><a href="/threads/pending-torrent" class="text-reset text-decoration-none">Pending fetch torrent (info_hash)</a></th>
          <td>{{ pending_fetch_torrent }}</td>
        </tr>
        <tr>
          <th><a href="/threads/skipped" class="text-reset text-decoration-none">Skipped by picker</a></th>
          <td>{{ skipped_by_picker }}</td>
        </tr>
        <tr>
          <th>No seeders / dormant</th>
          <td>{{ dormant }}</td>
        </tr>
        </tbody>
      </table>

      {% if scrape_status %}
      <h3>Scrape Status</h3>
      <div class="mb-2">
        <div><strong>Search cursor (normal):</strong> {{ search_cursor_normal }}</div>
        <div><strong>Search cursor (adult):</strong> {{ search_cursor_adult }}</div>
      </div>
      <table class="table table-bordered table-sm" style="max-width: 700px;">
        <thead>
          <tr>
            <th>Operation</th>
            <th>Last Run</th>
            <th>Result</th>
            <th>Detail</th>
          </tr>
        </thead>
        <tbody>
        {% for s in scrape_status %}
          <tr class="{% if s.last_result == 'running' %}table-info{% elif s.last_result == 'rate_limited' %}table-warning{% elif s.last_result == 'error' %}table-danger{% else %}table-success{% endif %}">
            <td>{{ s.name }}</td>
            <td>{{ s.last_run_at | timeago }}</td>
            <td>{{ s.last_result }}</td>
            <td>{{ s.detail }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
      {% endif %}
    </div>

    <div class="col-md-6">
      <h3>Download Progress</h3>
      <table class="table table-bordered">
        <tbody>
        <tr>
          <th>Total</th>
          <td>{{ total }}</td>
          <td>{{ total_size }}</td>
        </tr>
        <tr class="table-warning">
          <th><a href="/threads/pending-download" class="text-reset text-decoration-none">Pending to download {{ pending_to_download_pct }}</a></th>
          <td>{{ pending_to_download }}</td>
          <td>{{ pending_to_download_size }}</td>
        </tr>
        <tr class="table-info">
          <th><a href="/threads/downloading" class="text-reset text-decoration-none">Downloading {{ downloading_pct }}</a></th>
          <td>{{ downloading }}</td>
          <td>{{ downloading_size }}</td>
        </tr>
        {% for n in downloading_nodes %}
        <tr class="table-info">
          <td class="ps-4"><a href="/nodes/{{ n.node_id }}?status=downloading" class="text-reset text-decoration-none text-muted">{{ n.node_name }} ({{ n.dlspeed }})</a></td>
          <td>{{ n.count }}</td>
          <td>{{ n.size_fmt }}</td>
        </tr>
        {% endfor %}
        <tr class="table-success">
          <th><a href="/threads/done" class="text-reset text-decoration-none">Done {{ done_pct }}</a></th>
          <td>{{ done }}</td>
          <td>{{ done_size }}</td>
        </tr>
        {% for n in done_nodes %}
        <tr class="table-success">
          <td class="ps-4"><a href="/nodes/{{ n.node_id }}?status=done" class="text-reset text-decoration-none text-muted">{{ n.node_name }}</a></td>
          <td>{{ n.count }}</td>
          <td>{{ n.size_fmt }}</td>
        </tr>
        {% endfor %}
        <tr class="table-danger">
          <th><a href="/threads/failed" class="text-reset text-decoration-none">Failed {{ failed_pct }}</a></th>
          <td>{{ failed }}</td>
          <td>{{ failed_size }}</td>
        </tr>
        <tr class="table-secondary">
          <th><a href="/threads/removed" class="text-reset text-decoration-none">Removed {{ removed_by_client_pct }}</a></th>
          <td>{{ removed_by_client }}</td>
          <td>{{ removed_by_client_size }}</td>
        </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="container mt-4 mb-4">
  <a href="/detail">View daily detail &rarr;</a>
  &nbsp;&nbsp;|&nbsp;&nbsp;
  <a href="/nodes">View nodes &rarr;</a>
  &nbsp;&nbsp;|&nbsp;&nbsp;
  <a href="/threads/errors">Scrape errors &rarr;</a>
  &nbsp;&nbsp;|&nbsp;&nbsp;
  <a href="/exports">Export records &rarr;</a>
</div>

</body>
</html>
