<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport"
        content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>Progress</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"
          crossorigin="anonymous"></script>
</head>
<body>

<div class="container mt-4">
  <h2>Progress</h2>

  <div class="progress mb-3" style="height: 30px;">
    <div class="progress-bar" style="width: {{ skipped_pct }}%; background-color: #adb5bd;" role="progressbar" title="Skipped: {{ skipped }}"></div>
    <div class="progress-bar bg-secondary" role="progressbar" style="width: {{ pending_fetch_mediainfo_pct }}%" title="Pending mediainfo: {{ pending_fetch_mediainfo }}"></div>
    <div class="progress-bar bg-warning" role="progressbar" style="width: {{ pending_fetch_torrent_pct }}%" title="Pending torrent: {{ pending_fetch_torrent }}"></div>
    <div class="progress-bar bg-warning text-dark" role="progressbar" style="width: {{ pending_to_download_pct }}%" title="Pending download: {{ pending_to_download }}"></div>
    <div class="progress-bar bg-info" role="progressbar" style="width: {{ downloading_pct }}%" title="Downloading: {{ downloading }}"></div>
    <div class="progress-bar bg-danger" role="progressbar" style="width: {{ failed_pct }}%" title="Failed: {{ failed }}"></div>
    <div class="progress-bar bg-success" role="progressbar" style="width: {{ done_pct }}%" title="Done: {{ done }}">{{ done_pct }}%</div>
  </div>

  <div class="row">
    <div class="col-md-6">
      <h3>Scraping Progress <small class="text-muted fs-6">{{ search_cursor }}</small></h3>
      <table class="table table-bordered mb-4">
        <tbody>
        <tr>
          <th>Threads discovered (all categories)</th>
          <td>{{ scraped_total }}</td>
        </tr>
        <tr>
          <th>Total</th>
          <td>{{ total }}</td>
        </tr>
        <tr class="table-warning">
          <th><a href="/threads/pending-mediainfo" class="text-reset text-decoration-none">Pending fetch mediainfo</a></th>
          <td>{{ pending_fetch_mediainfo }}</td>
        </tr>
        <tr class="table-warning">
          <th><a href="/threads/pending-torrent" class="text-reset text-decoration-none">Pending fetch torrent (info_hash)</a></th>
          <td>{{ pending_fetch_torrent }}</td>
        </tr>
        <tr>
          <th>Skipped / No seeders</th>
          <td>{{ skipped }}</td>
        </tr>
        </tbody>
      </table>
    </div>

    <div class="col-md-6">
      <h3>Download Progress</h3>
      <table class="table table-bordered">
        <tbody>
        <tr>
          <th>Total</th>
          <td>{{ total }}</td>
          <td>{{ total_size }}</td>
        </tr>
        <tr class="table-warning">
          <th><a href="/threads/pending-download" class="text-reset text-decoration-none">Pending to download</a></th>
          <td>{{ pending_to_download }}</td>
          <td>{{ pending_to_download_size }}</td>
        </tr>
        <tr class="table-info">
          <th><a href="/threads/downloading" class="text-reset text-decoration-none">Downloading</a></th>
          <td>{{ downloading }}</td>
          <td>{{ downloading_size }}</td>
        </tr>
        {% for n in downloading_nodes %}
        <tr class="table-info">
          <td class="ps-4"><a href="/nodes/{{ n.node_id }}" class="text-reset text-decoration-none text-muted">{{ n.node_name }}</a></td>
          <td>{{ n.count }}</td>
          <td>{{ n.size_fmt }}</td>
        </tr>
        {% endfor %}
        <tr class="table-success">
          <th><a href="/threads/done" class="text-reset text-decoration-none">Done</a></th>
          <td>{{ done }}</td>
          <td>{{ done_size }}</td>
        </tr>
        {% for n in done_nodes %}
        <tr class="table-success">
          <td class="ps-4"><a href="/nodes/{{ n.node_id }}" class="text-reset text-decoration-none text-muted">{{ n.node_name }}</a></td>
          <td>{{ n.count }}</td>
          <td>{{ n.size_fmt }}</td>
        </tr>
        {% endfor %}
        <tr class="table-danger">
          <th><a href="/threads/failed" class="text-reset text-decoration-none">Failed</a></th>
          <td>{{ failed }}</td>
          <td>{{ failed_size }}</td>
        </tr>
        <tr class="table-secondary">
          <th><a href="/threads/removed" class="text-reset text-decoration-none">Removed</a></th>
          <td>{{ removed_by_client }}</td>
          <td>{{ removed_by_client_size }}</td>
        </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
</div>

<div class="container mt-4">
  <h3>Average Byte Rate per Week</h3>
  <div id="weeklyByteRateLoading" class="text-muted">Loading chart data...</div>
  <canvas id="weeklyByteRateChart" style="max-height: 350px; display: none;"></canvas>
</div>

<div class="container mt-4">
  <h3>Threads & Torrents Fetched per Week</h3>
  <div id="weeklyFetchLoading" class="text-muted">Loading chart data...</div>
  <canvas id="weeklyFetchChart" style="max-height: 350px; display: none;"></canvas>
</div>

<div class="container mt-4 mb-4">
  <a href="/detail">View daily detail (last 365 days) &rarr;</a>
  &nbsp;&nbsp;|&nbsp;&nbsp;
  <a href="/nodes">View nodes &rarr;</a>
</div>

<script>
  const NODE_ALIASES = {{ node_aliases | tojson }};
  function nodeLabel(nid) { return NODE_ALIASES[nid] || nid.slice(0, 8); }
  const DONE_TOTAL_BG = 'rgba(13, 110, 253, 0.18)';
  const DONE_TOTAL_BORDER = 'rgba(13, 110, 253, 1)';
  const NODE_DASH_PATTERNS = [
    [6, 4],
    [10, 4],
    [2, 4],
    [12, 3, 3, 3],
    [8, 2, 2, 2],
    [14, 5],
  ];

  function nodeDatasetStyle(index) {
    return {
      backgroundColor: DONE_TOTAL_BG,
      borderColor: DONE_TOTAL_BORDER,
      borderWidth: 1,
      borderDash: NODE_DASH_PATTERNS[index % NODE_DASH_PATTERNS.length],
    };
  }

  function formatByteRate(bps) {
    if (bps === 0) return '0 B/s';
    const units = ['B/s', 'KiB/s', 'MiB/s', 'GiB/s', 'TiB/s'];
    let i = 0;
    while (bps >= 1024 && i < units.length - 1) { bps /= 1024; i++; }
    return bps.toFixed(2) + ' ' + units[i];
  }

  function renderByteRateChart(data, fetchedData) {
    const labels = data.labels;
    const nodeIds = Object.keys(data.per_node);
    const fetchedMap = Object.fromEntries((fetchedData || []).map(d => [d.week, d.byte_rate]));
    const datasets = [
      {
        label: 'Downloaded',
        data: data.totals.map(d => d.byte_rate),
        backgroundColor: 'rgba(13, 110, 253, 0.3)',
        borderColor: 'rgba(13, 110, 253, 1)',
        borderWidth: 2,
      },
      {
        label: 'Fetched (need to download)',
        data: labels.map(l => fetchedMap[l] ?? 0),
        backgroundColor: 'rgba(220, 53, 69, 0.2)',
        borderColor: 'rgba(220, 53, 69, 1)',
        borderWidth: 2,
      },
      ...nodeIds.map((nid, i) => {
        return {
          label: nodeLabel(nid),
          data: data.per_node[nid],
          ...nodeDatasetStyle(i),
        };
      }),
    ];
    document.getElementById('weeklyByteRateLoading').style.display = 'none';
    document.getElementById('weeklyByteRateChart').style.display = '';
    new Chart(document.getElementById('weeklyByteRateChart'), {
      type: 'line',
      data: { labels, datasets },
      options: {
        responsive: true,
        scales: {
          y: {
            beginAtZero: true,
            ticks: { callback: value => formatByteRate(value) }
          }
        },
        plugins: {
          tooltip: {
            callbacks: {
              label: ctx => ctx.dataset.label + ': ' + formatByteRate(ctx.parsed.y)
            }
          },
        }
      }
    });
  }

  function renderFetchChart(chartData) {
    const threadData = chartData.weekly_thread_count;
    const torrentData = chartData.weekly_torrent_count;
    const doneData = chartData.weekly_done_count;
    const mediainfoData = chartData.weekly_mediainfo_count;

    const threadMap = Object.fromEntries(threadData.map(d => [d.week, d.count]));
    const torrentMap = Object.fromEntries(torrentData.map(d => [d.week, d.count]));
    const mediainfoMap = Object.fromEntries(mediainfoData.map(d => [d.week, d.count]));
    const allWeeks = [...new Set([
      ...threadData.map(d => d.week),
      ...torrentData.map(d => d.week),
      ...(doneData.labels || []),
      ...mediainfoData.map(d => d.week),
    ])].sort();

    const doneNodeIds = Object.keys(doneData.per_node || {});
    const doneTotalMap = {};
    (doneData.labels || []).forEach((l, i) => { doneTotalMap[l] = doneData.totals[i]; });
    const doneNodeMaps = {};
    doneNodeIds.forEach(nid => {
      const m = {};
      (doneData.labels || []).forEach((l, i) => { m[l] = doneData.per_node[nid][i]; });
      doneNodeMaps[nid] = m;
    });

    const doneDatasets = [
      {
        label: 'Done (total)',
        data: allWeeks.map(d => doneTotalMap[d] ?? 0),
        backgroundColor: DONE_TOTAL_BG,
        borderColor: DONE_TOTAL_BORDER,
        borderWidth: 2,
      },
      ...doneNodeIds.map((nid, i) => {
        return {
          label: 'Done ' + nodeLabel(nid),
          data: allWeeks.map(d => doneNodeMaps[nid][d] ?? 0),
          ...nodeDatasetStyle(i),
        };
      }),
    ];

    document.getElementById('weeklyFetchLoading').style.display = 'none';
    document.getElementById('weeklyFetchChart').style.display = '';
    new Chart(document.getElementById('weeklyFetchChart'), {
      type: 'line',
      data: {
        labels: allWeeks,
        datasets: [
          {
            label: 'Threads Fetched',
            data: allWeeks.map(d => threadMap[d] ?? 0),
            backgroundColor: 'rgba(25, 135, 84, 0.5)',
            borderColor: 'rgba(25, 135, 84, 1)',
            borderWidth: 1,
          },
          {
            label: 'Mediainfo Fetched',
            data: allWeeks.map(d => mediainfoMap[d] ?? 0),
            backgroundColor: 'rgba(111, 66, 193, 0.5)',
            borderColor: 'rgba(111, 66, 193, 1)',
            borderWidth: 1,
          },
          {
            label: 'Torrents Fetched',
            data: allWeeks.map(d => torrentMap[d] ?? 0),
            backgroundColor: 'rgba(255, 193, 7, 0.5)',
            borderColor: 'rgba(255, 193, 7, 1)',
            borderWidth: 1,
          },
          ...doneDatasets,
        ]
      },
      options: {
        responsive: true,
        scales: { y: { beginAtZero: true } },
      }
    });
  }

  fetch('/api/weekly-charts')
    .then(r => r.json())
    .then(data => {
      renderByteRateChart(data.weekly_byte_rate, data.weekly_fetched_size);
      renderFetchChart(data);
    })
    .catch(err => {
      document.getElementById('weeklyByteRateLoading').textContent = 'Failed to load chart data';
      document.getElementById('weeklyFetchLoading').textContent = 'Failed to load chart data';
    });
</script>
</body>
</html>
