<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport"
        content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>Progress</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">
</head>
<body>

<div id="app">
{% include "index_content.html.j2" %}
</div>

<div class="container mt-4 mb-4">
  <label class="form-check-label me-2"><input type="checkbox" class="form-check-input me-1" id="auto-refresh"> Auto-refresh</label>
  <a href="/detail">View daily detail &rarr;</a>
  &nbsp;&nbsp;|&nbsp;&nbsp;
  <a href="/nodes">View nodes &rarr;</a>
  &nbsp;&nbsp;|&nbsp;&nbsp;
  <a href="/threads/errors">Scrape errors &rarr;</a>
  &nbsp;&nbsp;|&nbsp;&nbsp;
  <a href="/exports">Export records &rarr;</a>
</div>

<script>
(function() {
  const cb = document.getElementById("auto-refresh");
  const app = document.getElementById("app");
  let es = null;

  function start() {
    if (es) return;
    es = new EventSource("/api/progress/stream");
    es.addEventListener("update", function(e) {
      try {
        var d = JSON.parse(e.data);
        app.innerHTML = d.html;
      } catch (_) {}
    });
    es.onerror = function() {
      es.close();
      es = null;
      if (cb.checked) setTimeout(start, 3000);
    };
  }

  function stop() {
    if (es) { es.close(); es = null; }
  }

  cb.addEventListener("change", function() {
    if (cb.checked) start(); else stop();
  });
})();
</script>
</body>
</html>
