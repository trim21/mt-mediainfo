<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport"
        content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>Progress</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"
          crossorigin="anonymous"></script>
</head>
<body>

<div class="container mt-4">
  <h2>Scraping Progress</h2>

  <div class="progress mb-3" style="height: 30px;">
    <div class="progress-bar bg-primary" role="progressbar"
         style="width: {{ scrape_pct }}%"
         title="Scraped">{{ scrape_pct }}%
    </div>
  </div>

  <table class="table table-bordered mb-4">
    <tbody>
    <tr>
      <th>Known max thread ID</th>
      <td>{{ known_max_id }}</td>
    </tr>
    <tr>
      <th>Max scraped thread ID</th>
      <td>{{ scraped_max_tid }}</td>
    </tr>
    <tr>
      <th>Threads scraped (all categories)</th>
      <td>{{ scraped_total }}</td>
    </tr>
    <tr>
      <th>Threads in selected categories</th>
      <td>{{ total }}</td>
    </tr>
    </tbody>
  </table>

  <div class="row">
    <div class="col-md-6">
      <h2>Mediainfo Progress</h2>

      <div class="progress mb-3" style="height: 30px;">
        <div class="progress-bar bg-success" role="progressbar"
             style="width: {{ done_pct }}%"
             title="Done">{{ done_pct }}%
        </div>
        <div class="progress-bar bg-info" role="progressbar"
             style="width: {{ in_progress_pct }}%"
             title="In Progress">{{ in_progress_pct }}%
        </div>
        <div class="progress-bar bg-danger" role="progressbar"
             style="width: {{ failed_pct }}%"
             title="Failed">{{ failed_pct }}%
        </div>
      </div>

      <table class="table table-bordered">
        <tbody>
        <tr>
          <th>Total (selected categories)</th>
          <td>{{ total }}</td>
        </tr>
        <tr class="table-success">
          <th>Done (has mediainfo)</th>
          <td>{{ done }} ({{ done_size }})</td>
        </tr>
        <tr class="table-info">
          <th>In progress (downloading)</th>
          <td>{{ in_progress }}</td>
        </tr>
        <tr class="table-danger">
          <th>Failed</th>
          <td>{{ failed }}</td>
        </tr>
        <tr class="table-warning">
          <th>Pending (waiting)</th>
          <td>{{ pending }} ({{ pending_size }})</td>
        </tr>
        <tr>
          <th>Skipped / No seeders</th>
          <td>{{ skipped }}</td>
        </tr>
        </tbody>
      </table>
    </div>

    <div class="col-md-6">
      <h3>Average Byte Rate</h3>
      <table class="table table-bordered">
        <tbody>
        <tr>
          <th>Last 1 day</th>
          <td>{{ byte_rate_1d }}</td>
        </tr>
        <tr>
          <th>Last 3 days</th>
          <td>{{ byte_rate_3d }}</td>
        </tr>
        <tr>
          <th>Last 1 week</th>
          <td>{{ byte_rate_1w }}</td>
        </tr>
        <tr>
          <th>Last 2 weeks</th>
          <td>{{ byte_rate_2w }}</td>
        </tr>
        <tr>
          <th>Last 1 month</th>
          <td>{{ byte_rate_1m }}</td>
        </tr>
        <tr>
          <th>Last 3 months</th>
          <td>{{ byte_rate_3m }}</td>
        </tr>
        <tr>
          <th>Last 6 months</th>
          <td>{{ byte_rate_6m }}</td>
        </tr>
        <tr>
          <th>Last 1 year</th>
          <td>{{ byte_rate_1y }}</td>
        </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="row mt-4">
    <div class="col-md-6">
      <h3>Download Statistics</h3>
      <table class="table table-bordered">
        <tbody>
        <tr>
          <th>Current downloading size</th>
          <td>{{ downloading_size }} / {{ total_process_size }}</td>
        </tr>
        <tr>
          <th>Pending (waiting to download)</th>
          <td>{{ pending }} ({{ pending_size }})</td>
        </tr>
        <tr>
          <th>Single torrent size limit</th>
          <td>{{ single_torrent_size_limit }}</td>
        </tr>
        </tbody>
      </table>
    </div>

    <div class="col-md-6">
      <h3>Bottleneck Analysis</h3>
      <table class="table table-bordered">
        <tbody>
        <tr>
          <th colspan="2" class="table-secondary">API / Scraping</th>
        </tr>
        <tr>
          <th>Missing torrent data (info_hash not fetched)</th>
          <td>{{ missing_torrent }} / {{ total }}</td>
        </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="container mt-4">
  <h3>Average Byte Rate per Day (last 2 years)</h3>
  <canvas id="weeklyByteRateChart" style="max-height: 350px;"></canvas>
</div>

<div class="container mt-4">
  <h3>Threads & Torrents Fetched per Day (last 2 years)</h3>
  <canvas id="dailyFetchChart" style="max-height: 350px;"></canvas>
</div>

<script>
  (async () => {
    const resp = await fetch('/stats/weekly-byte-rate');
    const data = await resp.json();
    const labels = data.map(d => d.week.slice(0, 10));
    const byteRates = data.map(d => d.byte_rate);
    const sizes = data.map(d => d.total_size);

    new Chart(document.getElementById('weeklyByteRateChart'), {
      type: 'bar',
      data: {
        labels,
        datasets: [{
          label: 'Avg Byte Rate',
          data: byteRates,
          backgroundColor: 'rgba(13, 110, 253, 0.5)',
          borderColor: 'rgba(13, 110, 253, 1)',
          borderWidth: 1,
        }]
      },
      options: {
        responsive: true,
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              callback: (_, i) => data[i]?.byte_rate_fmt ?? ''
            }
          }
        },
        plugins: {
          tooltip: {
            callbacks: {
              label: ctx => [
                'Avg rate: ' + data[ctx.dataIndex].byte_rate_fmt,
                'Total size: ' + data[ctx.dataIndex].total_size_fmt,
              ]
            }
          },
          legend: { display: false }
        }
      }
    });

    // Thread & torrent fetches per day chart
    const [threadResp, torrentResp, doneResp] = await Promise.all([
      fetch('/stats/daily-thread-count'),
      fetch('/stats/daily-torrent-count'),
      fetch('/stats/daily-done-count'),
    ]);
    const threadData = await threadResp.json();
    const torrentData = await torrentResp.json();
    const doneData = await doneResp.json();

    const threadMap = Object.fromEntries(threadData.map(d => [d.day.slice(0, 10), d.count]));
    const torrentMap = Object.fromEntries(torrentData.map(d => [d.day.slice(0, 10), d.count]));
    const doneMap = Object.fromEntries(doneData.map(d => [d.day.slice(0, 10), d.count]));
    const allDays = [...new Set([
      ...threadData.map(d => d.day.slice(0, 10)),
      ...torrentData.map(d => d.day.slice(0, 10)),
      ...doneData.map(d => d.day.slice(0, 10)),
    ])].sort();

    new Chart(document.getElementById('dailyFetchChart'), {
      type: 'line',
      data: {
        labels: allDays,
        datasets: [
          {
            label: 'Threads Fetched',
            data: allDays.map(d => threadMap[d] ?? 0),
            backgroundColor: 'rgba(25, 135, 84, 0.5)',
            borderColor: 'rgba(25, 135, 84, 1)',
            borderWidth: 1,
          },
          {
            label: 'Torrents Fetched',
            data: allDays.map(d => torrentMap[d] ?? 0),
            backgroundColor: 'rgba(255, 193, 7, 0.5)',
            borderColor: 'rgba(255, 193, 7, 1)',
            borderWidth: 1,
          },
          {
            label: 'Downloads Done',
            data: allDays.map(d => doneMap[d] ?? 0),
            backgroundColor: 'rgba(13, 110, 253, 0.5)',
            borderColor: 'rgba(13, 110, 253, 1)',
            borderWidth: 1,
          },
        ]
      },
      options: {
        responsive: true,
        scales: { y: { beginAtZero: true } },
      }
    });
  })();
</script>
</body>
</html>
