<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport"
        content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>Node {{ node_name }}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">
</head>
<body>

<div class="container-fluid mt-4 px-4">
  <p><a href="/nodes">&larr; Back to Nodes</a></p>
  <h2>Node <code>{{ node_name }}</code> <small class="text-muted fs-6">({{ jobs | length }} jobs)</small></h2>
  <p class="text-muted">Full ID: <code>{{ node_id }}</code> &mdash; Version: <code>{{ version or '-' }}</code> &mdash; Last seen: {{ last_seen | fmt_dt }}</p>
  {% if node_debug_info %}
  <div class="mb-3">
    <strong>Node Debug Info:</strong>
    {% for key, value in node_debug_info.items() %}
      <span class="badge bg-light text-dark border me-1"><code>{{ key }}</code>: <code>{{ value }}</code></span>
    {% endfor %}
  </div>
  {% endif %}
  <button id="ping-btn" class="btn btn-sm btn-outline-primary mb-3" onclick="pingNode('{{ node_id }}')">Ping</button>
  <span id="ping-result" class="ms-2 small"></span>

  <ul class="nav nav-tabs mb-3">
    <li class="nav-item">
      <a class="nav-link {% if status == 'downloading' %}active{% endif %}"
         href="/nodes/{{ node_id }}?status=downloading">Downloading</a>
    </li>
    <li class="nav-item">
      <a class="nav-link {% if status == 'done' %}active{% endif %}"
         href="/nodes/{{ node_id }}?status=done">Done</a>
    </li>
  </ul>

  {% if total_count is defined and total_count > page_size %}
  <div class="d-flex justify-content-between align-items-center mb-2">
    <span class="text-muted small">{{ (page - 1) * page_size + 1 }}-{{ [page * page_size, total_count] | min }} of {{ total_count }}</span>
    <div class="btn-group btn-group-sm">
      <a class="btn btn-outline-secondary{% if not has_prev %} disabled{% endif %}"
         href="/nodes/{{ node_id }}?status={{ status }}&page={{ prev_page if prev_page else 1 }}{% if sort %}&sort={{ sort }}&order={{ order }}{% endif %}">Previous</a>
      <a class="btn btn-outline-secondary{% if not has_next %} disabled{% endif %}"
         href="/nodes/{{ node_id }}?status={{ status }}&page={{ next_page if next_page else total_pages }}{% if sort %}&sort={{ sort }}&order={{ order }}{% endif %}">Next</a>
    </div>
  </div>
  {% endif %}

  {% macro sort_link(key, label) %}
    {% if sort == key %}
      <a href="/nodes/{{ node_id }}?status={{ status }}&sort={{ key }}&order={{ 'desc' if order == 'asc' else 'asc' }}"
         class="text-decoration-none text-dark">{{ label }} {{ '▲' if order == 'asc' else '▼' }}</a>
    {% else %}
      <a href="/nodes/{{ node_id }}?status={{ status }}&sort={{ key }}&order=asc"
         class="text-decoration-none text-dark">{{ label }}</a>
    {% endif %}
  {% endmacro %}

  <table class="table table-bordered table-hover table-sm">
    <thead class="table-light">
     <tr>
       <th>{{ sort_link('tid', 'TID') }}</th>
       <th>Status</th>
       <th>{{ sort_link('seeders', 'Seeders') }}</th>
       <th>{{ sort_link('size', 'Size') }}</th>
       <th>{{ sort_link('selected_size', 'Selected Size') }}</th>
        {% if status == 'downloading' %}
        <th>{{ sort_link('progress', 'Progress') }}</th>
        <th>{{ sort_link('speed', 'Speed') }}</th>
        <th>{{ sort_link('eta', 'ETA') }}</th>
        <th>{{ sort_link('no_progress', 'No Progress Since') }}</th>
        <th>Error</th>
        {% endif %}
       <th>{{ sort_link('started', 'Started') }}</th>
       <th>{{ sort_link('completed' if status == 'done' else 'updated', 'Completed' if status == 'done' else 'Updated') }}</th>
       <th>Link</th>
       <th>Debug Info</th>
       <th>Actions</th>
     </tr>
    </thead>
    <tbody>
    {% for j in jobs %}
    <tr id="job-{{ j.info_hash }}">
       <td><a href="/thread/{{ j.tid }}">{{ j.tid }}</a></td>
      <td>
        {% if j.status == 'downloading' %}<span class="badge bg-info text-dark">{{ j.status }}</span>
        {% elif j.status == 'done' %}<span class="badge bg-success">{{ j.status }}</span>
        {% elif j.status == 'failed' %}<span class="badge bg-danger">{{ j.status }}</span>
        {% elif j.status == 'removed-by-client' %}<span class="badge bg-secondary">Removed</span>
        {% else %}<span class="badge bg-warning text-dark">{{ j.status }}</span>
        {% endif %}
      </td>
      <td>{{ j.seeders }}</td>
       <td>{{ j.size_fmt }}</td>
       <td>{{ j.selected_size_fmt }}</td>
        {% if status == 'downloading' %}
        <td>{{ j.progress_fmt }}%</td>
        <td>{{ j.speed_fmt }}</td>
        <td>{{ j.eta_fmt }}</td>
        <td>{{ j.no_progress_since }}</td>
        <td>{% if j.error_message %}<span class="text-danger" title="{{ j.error_message }}">{{ j.error_message[:50] }}{% if j.error_message | length > 50 %}&hellip;{% endif %}</span>{% endif %}</td>
        {% endif %}
       <td>{{ j.start_download_time | fmt_dt }}</td>
       <td>{{ (j.completed_at if status == 'done' else j.updated_at) | fmt_dt }}</td>
      <td><a href="https://kp.m-team.cc/detail/{{ j.tid }}" target="_blank">MT</a></td>
      <td>
        {% if j.debug_info and j.debug_info != '{}' %}
          {% if j.debug_info.file_selection %}
            <details>
              <summary>Files ({{ j.debug_info.file_selection | length }})</summary>
              <table class="table table-sm table-bordered mb-0" style="font-size: 0.75rem;">
                <thead><tr><th>#</th><th>Name</th><th>Size</th><th>Priority</th></tr></thead>
                <tbody>
                {% for f in j.debug_info.file_selection %}
                  <tr{% if f.priority == 0 %} class="text-muted"{% endif %}>
                    <td>{{ f.index }}</td>
                    <td style="word-break: break-all;">{{ f.name }}</td>
                    <td>{{ f.size }}</td>
                    <td>{{ f.priority }}</td>
                  </tr>
                {% endfor %}
                </tbody>
              </table>
            </details>
          {% else %}
            <span class="text-muted small">{{ j.debug_info }}</span>
          {% endif %}
        {% else %}
          <span class="text-muted">-</span>
        {% endif %}
      </td>
      <td>
        <button class="btn btn-sm btn-outline-danger" onclick="deleteTorrent('{{ node_id }}', '{{ j.info_hash }}')">Delete</button>
      </td>
    </tr>
    {% endfor %}
    </tbody>
  </table>
</div>

<script>
async function pingNode(nodeId) {
  const btn = document.getElementById('ping-btn');
  const result = document.getElementById('ping-result');
  btn.disabled = true;
  btn.textContent = 'Pinging...';
  result.textContent = '';
  result.className = 'ms-2 small';
  try {
    const resp = await fetch('/api/node/' + nodeId + '/rpc', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({method: 'ping', payload: {}})
    });
    const data = await resp.json();
    if (!resp.ok) {
      result.textContent = 'Error: ' + (data.error || resp.statusText);
      result.className = 'ms-2 small text-danger';
    } else {
      result.textContent = 'Queued (id: ' + data.id + ')';
      result.className = 'ms-2 small text-success';
    }
  } catch (e) {
    result.textContent = 'Request failed: ' + e;
    result.className = 'ms-2 small text-danger';
  } finally {
    btn.disabled = false;
    btn.textContent = 'Ping';
  }
}

async function deleteTorrent(nodeId, infoHash) {
  if (!confirm('确定删除该种子？此操作将删除种子及已下载的文件。')) return;
  const btn = event.target;
  btn.disabled = true;
  btn.textContent = '...';
  try {
    const resp = await fetch('/api/node/' + nodeId + '/rpc', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({method: 'delete-torrent', payload: {info_hash: infoHash}})
    });
    const data = await resp.json();
    if (!resp.ok) {
      alert('Error: ' + (data.error || resp.statusText));
      btn.disabled = false;
      btn.textContent = 'Delete';
      return;
    }
    const row = document.getElementById('job-' + infoHash);
    if (row) row.style.opacity = '0.4';
    btn.textContent = 'Queued';
  } catch (e) {
    alert('Request failed: ' + e);
    btn.disabled = false;
    btn.textContent = 'Delete';
  }
}
</script>

</body>
</html>
